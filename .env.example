# WAT framework — environment template.
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
#
#   cp .env.example .env   (PowerShell: Copy-Item .env.example .env)

# --- Backend / LLM (already read by backend/services/ollama_service.py) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.6

# --- Cloud LLM: OpenRouter (backend/services/openrouter_service.py) ---
# The per-investor API key is entered in the AI Assistant UI and stored in the DB.
# These env vars only override the model / host. Model ids are "provider/model"
# (e.g. openai/gpt-oss-120b:free, openai/gpt-4o-mini) — see https://openrouter.ai/models
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Database (backend/database.py) ---
DATABASE_URL=sqlite:///./tunisia_invest.db

# --- Auth (backend/routers/auth.py — currently hard-coded, move it here) ---
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production

# --- Newsletter email delivery (backend/services/email_service.py) ---
# OPTIONAL. Leave SMTP_HOST blank to keep the email seam INACTIVE: the Sector
# Thesis Scout newsletter is still generated and stored, just not emailed.
# To activate weekly delivery to every investor, fill these in (Gmail needs an
# App Password with 2FA — stdlib smtplib, no extra dependency):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# NEWSLETTER_FROM=you@gmail.com
# NEWSLETTER_FROM_NAME=TunisIA Invest
# SMTP_DEBUG=1   # uncomment to print the raw SMTP conversation (troubleshooting only)

# --- WAT tool credentials (add as workflows need them) ---
# Examples — uncomment / add the ones your tools actually use:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=credentials.json
